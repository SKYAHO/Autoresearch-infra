project_id = "your-gcp-project-id"

region      = "asia-northeast3"
zone        = "asia-northeast3-a"
environment = "dev"
name_prefix = "autoresearch"

labels = {
  owner = "infra"
}

# dev VPC / subnet (#2)
dev_subnet_cidr              = "10.10.0.0/20"
enable_private_google_access = true

# dev Cloud SQL (#4)
db_database_version     = "POSTGRES_15"
db_tier                 = "db-f1-micro"
db_name                 = "autoresearch"
db_app_user             = "app"
sql_deletion_protection = false
private_services_cidr   = "192.168.0.0/20" # 현재 dev apply 값. dev subnet/GKE 대역과 미중복

# GKE (#5)
gke_master_ipv4_cidr           = "172.16.0.0/28" # private 컨트롤 플레인. dev subnet/private services와 미중복
gke_pods_cidr                  = "172.16.64.0/20"
gke_services_cidr              = "172.16.128.0/24"
gke_machine_type               = "e2-standard-4"
gke_node_count_min             = 1
gke_node_count_max             = 2
master_authorized_networks     = ["203.0.113.10/32"] # IP 엔드포인트 예비 경로용(선택). 기본 kubectl 접속은 --dns-endpoint(#45)
airflow_gke_node_pool_name     = "airflow-dev"
airflow_gke_machine_type       = "e2-standard-2"
airflow_gke_node_count_min     = 1
airflow_gke_node_count_max     = 1
airflow_k8s_namespace          = "airflow"
airflow_batch_k8s_service_account = "autoresearch-batch"
airflow_api_k8s_secret_name    = "autoresearch-airflow-env"

raw_data_bucket_location                         = "asia-northeast3"
raw_data_bucket_storage_class                    = "STANDARD"
raw_data_noncurrent_version_retention_days       = 30

bigquery_location                                = "asia-northeast3"
bigquery_delete_contents_on_destroy              = false

feast_bucket_location                            = "asia-northeast3"
feast_bucket_storage_class                       = "STANDARD"
feast_registry_noncurrent_version_retention_days = 30
feast_staging_object_retention_days              = 7

# dev proxy Cloud Run (#27)
proxy_image               = "" # 비우면 dev AR 리포의 proxy:dev-20260708-001 예시 태그. 재배포 시 새 tag/digest로 변경
proxy_ingress             = "INGRESS_TRAFFIC_INTERNAL_ONLY"
proxy_max_instances       = 1
proxy_cpu                 = "1"
proxy_memory              = "512Mi"
proxy_invoker_members     = [] # airflow-batch는 코드에서 부여. 추가 호출 주체만 "serviceAccount:..."로 추가
proxy_deletion_protection = false

# Airflow (#32) — 기본값으로 충분. KSA 이름을 바꿀 때만 기입
# (airflow_k8s_namespace는 위 GKE 블록에서 지정)
# airflow_k8s_service_account  = "airflow"

# dev Bastion Host (#47) — IAP 터널 전용
bastion_enabled      = true
bastion_machine_type = "e2-micro"
bastion_disk_size_gb = 10
bastion_image        = "debian-cloud/debian-12"

# Airflow UI 내부 노출 (#48)
internal_dns_domain = "dev.autoresearch.internal"
