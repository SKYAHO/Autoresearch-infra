project_id            = "your-gcp-project-id"
region                = "asia-northeast3"
zone                  = "asia-northeast3-a"
gke_cluster_name      = "autoresearch-dev-gke"
resource_prefix       = "autoresearch-dev"
# Cloud SQL private IP가 속한 PSA 대역. dev root private_services_cidr와 반드시
# 일치해야 한다(현재 `autoresearch-dev-private-sql-range` = 192.168.0.0/20).
# 불일치 시 airflow egress NetworkPolicy가 5432를 차단해 webserver가 DB에
# 접속하지 못한다(#253).
private_services_cidr = "192.168.0.0/20"

# Optional. Empty value derives:
# autoresearch-dev-airflow@<project_id>.iam.gserviceaccount.com
airflow_gcp_service_account_email = ""

# Optional. Empty value derives:
# autoresearch-dev-airflow-cd@<project_id>.iam.gserviceaccount.com
airflow_deployer_service_account_email = ""

airflow_k8s_namespace       = "airflow"
airflow_k8s_service_account = "airflow"

# Keep real Google accounts in local terraform.tfvars only.
installer_user_emails = [
  "teammate-1@example.com",
  "teammate-2@example.com",
]

# Airflow UI 내부 노출 (#48)
ui_ingress_source_cidr = "10.10.0.0/20"

# GKE services 2차 대역 (#122). dev root gke_services_cidr와 일치.
cluster_services_cidr = "172.16.128.0/24"
