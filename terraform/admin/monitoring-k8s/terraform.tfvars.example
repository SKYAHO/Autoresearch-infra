project_id       = "your-gcp-project-id"
region           = "asia-northeast3"
zone             = "asia-northeast3-a"
gke_cluster_name = "autoresearch-dev-gke"

monitoring_namespace = "monitoring"


# Secret payload는 Terraform 밖에서 만들고, 이름과 key만 Terraform에서 참조합니다.

# Keep real Google accounts in local terraform.tfvars only.
monitoring_port_forward_user_emails = [
  "teammate-1@example.com",
  "teammate-2@example.com",
]
